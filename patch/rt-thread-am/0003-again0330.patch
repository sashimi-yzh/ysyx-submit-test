+ 
++
++void wrap_funt(void *args) {
++  rt_ubase_t * stack_tmp = (rt_ubase_t *)args;
++  rt_ubase_t  texit = *stack_tmp;
++  stack_tmp++;
++  rt_ubase_t  parameter = *stack_tmp;
++  stack_tmp++;
++  rt_ubase_t  tentry = *stack_tmp;
++  ((void (*)())tentry)(parameter);
++  ((void (*)())texit)();
++}
++
+ rt_uint8_t *rt_hw_stack_init(void *tentry, void *parameter, rt_uint8_t *stack_addr, void *texit) {
+-  assert(0);
+-  return NULL;
++
++
++  Area stack;
++  
++  stack.end = (rt_uint8_t *)(((rt_ubase_t)stack_addr & ~(sizeof(stack_addr)-1))); //align
++  stack.start = stack.end - sizeof(Context);
++  rt_ubase_t * stack_tmp = (rt_ubase_t *)stack.start-4;
++  
++  *stack_tmp = (rt_ubase_t )tentry;
++  stack_tmp--;
++  *stack_tmp = (rt_ubase_t )parameter;
++  stack_tmp--;
++  *stack_tmp = (rt_ubase_t )texit;
++  Context *a = kcontext(stack,wrap_funt,stack_tmp);
++  return (rt_uint8_t *)a;
+ }
