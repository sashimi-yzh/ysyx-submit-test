From ea311efd70a7a9f333eea460e0f1c7a14e450259 Mon Sep 17 00:00:00 2001
From: 24011211232-Deng Xidian <1447762756@qq.com>
Date: Sat, 27 Dec 2025 19:23:35 +0800
Subject: [PATCH 2/7] commit_b2

---
 bsp/abstract-machine/Makefile     |  2 +-
 bsp/abstract-machine/extra.ld     |  5 ++-
 bsp/abstract-machine/extra_soc.ld | 56 +++++++++++++++++++++++++++++++
 3 files changed, 59 insertions(+), 4 deletions(-)
 create mode 100644 bsp/abstract-machine/extra_soc.ld

diff --git a/bsp/abstract-machine/Makefile b/bsp/abstract-machine/Makefile
index 8d70f31..e2def6d 100644
--- a/bsp/abstract-machine/Makefile
+++ b/bsp/abstract-machine/Makefile
@@ -8,7 +8,7 @@ NAME = rtthread
 SRCS = $(shell find src -name "*.c")
 CFLAGS += -DHAVE_CCONFIG_H -D__RTTHREAD__
 CFLAGS += -Wno-nonnull-compare
-LDFLAGS += -T extra.ld
+LDFLAGS += -T $(if $(findstring ysyxSoC,$(ARCH)),extra_soc.ld,extra.ld)
 -include $(FILE_MK)
 -include $(AM_APPS_MK)
 include $(AM_HOME)/Makefile
diff --git a/bsp/abstract-machine/extra.ld b/bsp/abstract-machine/extra.ld
index 5cdc656..7a2dc48 100644
--- a/bsp/abstract-machine/extra.ld
+++ b/bsp/abstract-machine/extra.ld
@@ -1,6 +1,6 @@
 SECTIONS {
   .data.extra : {
-    /* section information for finsh shell */
+
     __fsymtab_start = .;
     KEEP(*(FSymTab))
     __fsymtab_end = .;
@@ -10,7 +10,6 @@ SECTIONS {
     __vsymtab_end = .;
     . = ALIGN(8);
 
-    /* section information for initial. */
     . = ALIGN(8);
     __rt_init_start = .;
     KEEP(*(SORT(.rti_fn*)))
@@ -32,7 +31,7 @@ SECTIONS {
 INSERT BEFORE .data;
 
 SECTIONS {
-  .bss.extra : {
+  .bss.extra (NOLOAD) : {
     . = ALIGN(8);
     __am_apps_bss_start = .;
     *(__am_apps.bss*)
diff --git a/bsp/abstract-machine/extra_soc.ld b/bsp/abstract-machine/extra_soc.ld
new file mode 100644
index 0000000..fd138d7
--- /dev/null
+++ b/bsp/abstract-machine/extra_soc.ld
@@ -0,0 +1,56 @@
+MEMORY {
+    FLASH (rx) : ORIGIN = 0x30000000, LENGTH = 0x1000000
+    SDRAM (rwx) : ORIGIN = 0xa0000000, LENGTH = 0x4000000
+}
+
+SECTIONS {
+  .data.extra : ALIGN(8) {
+
+    __fsymtab_start = .;
+    KEEP(*(FSymTab))
+    __fsymtab_end = .;
+    . = ALIGN(8);
+    __vsymtab_start = .;
+    KEEP(*(VSymTab))
+    __vsymtab_end = .;
+    . = ALIGN(8);
+
+    . = ALIGN(8);
+    __rt_init_start = .;
+    KEEP(*(SORT(.rti_fn*)))
+    __rt_init_end = .;
+    . = ALIGN(8);
+
+    __rt_utest_tc_tab_start = .;
+    KEEP(*(UtestTcTab))
+    __rt_utest_tc_tab_end = .;
+
+    . = ALIGN(8);
+    __am_apps_data_start = .;
+    *(__am_apps.data*)
+    *(__am_apps.sdata*)
+    __am_apps_data_end = .;
+    . = ALIGN(8);
+  } > SDRAM AT > FLASH
+  
+  _data_extra_start = ADDR(.data.extra);
+  _data_extra_end = _data_extra_start + SIZEOF(.data.extra);
+  _data_extra_load = LOADADDR(.data.extra);
+} 
+INSERT BEFORE .data;
+
+SECTIONS {
+  .bss.extra (NOLOAD) : ALIGN(8){
+    . = ALIGN(8);
+    __am_apps_bss_start = .;
+    *(__am_apps.bss*)
+    *(__am_apps.sbss*)
+    *(__am_apps.scommon*)
+    __am_apps_bss_end = .;
+    . = ALIGN(8);
+  } > SDRAM
+  _bss_extra_start = ADDR(.bss.extra);
+  _bss_extra_end = _bss_extra_start + SIZEOF(.bss.extra);
+  /* _bss_extra_load = LOADADDR(.bss.extra); */
+} 
+INSERT BEFORE .bss;
-- 
