+#define A0_IDX 10
+#define arg0 c->gpr[A0_IDX]
+rt_base_t g_from;
+rt_base_t g_to;
 static Context* ev_handler(Event e, Context *c) {
   switch (e.event) {
-    case EVENT_YIELD:  {
-      rt_thread_t cp = rt_thread_self(); 
-      rt_ubase_t to = cp->user_data;
-      c = *(Context**)to; // 
