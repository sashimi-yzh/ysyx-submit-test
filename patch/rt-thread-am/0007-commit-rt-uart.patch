+  // static const char *p = "";
+  // return (*p != '\0' ? *(p ++) : -1);
+
+  char ch = io_read(AM_UART_RX).data;
+  
+  if (ch == (char)-1 && (ch & 0xff) == 0) {
+    return -1;
+  }
+  else {
+    return ch;
+  }
+
 }
 
