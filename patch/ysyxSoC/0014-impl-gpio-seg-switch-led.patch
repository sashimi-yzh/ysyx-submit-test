From: Wang Yi Jie <miwyj@mail.scut.edu.cn>
Date: Sun, 25 Jan 2026 23:34:44 +0800
Subject: [PATCH 14/28] impl gpio seg switch led

---
 src/Top.scala         |   1 +
 src/device/GPIO.scala | 110 ++++++++++++++++++++++++++++++++++++++----
 src/device/SPI.scala  |   2 +-
 3 files changed, 102 insertions(+), 11 deletions(-)

diff --git a/src/Top.scala b/src/Top.scala
index c00378a6..8cd5a774 100644
--- a/src/Top.scala
+++ b/src/Top.scala
@@ -8,6 +8,7 @@ import freechips.rocketchip.diplomacy.LazyModule
 object Config {
   def hasChipLink: Boolean = false
   def sdramUseAXI: Boolean = false
+  def useFastFlash: Boolean = true
 }
 
 class ysyxSoCTop extends Module {
diff --git a/src/device/GPIO.scala b/src/device/GPIO.scala
index f770e96a..13fd6c3c 100644
--- a/src/device/GPIO.scala
+++ b/src/device/GPIO.scala
@@ -17,7 +17,9 @@ class GPIOIO extends Bundle {
 class GPIOCtrlIO extends Bundle {
   val clock = Input(Clock())
   val reset = Input(Reset())
-  val in = Flipped(new APBBundle(APBBundleParameters(addrBits = 32, dataBits = 32)))
+  val in = Flipped(
+    new APBBundle(APBBundleParameters(addrBits = 32, dataBits = 32))
+  )
   val gpio = new GPIOIO
 }
 
@@ -27,23 +29,111 @@ class gpio_top_apb extends BlackBox {
 
 class gpioChisel extends Module {
   val io = IO(new GPIOCtrlIO)
+
+  val led = Reg(UInt(16.W))
+  io.gpio.out := led
+
+  val segBCD = Reg(Vec(8, UInt(4.W)))
+
+  val bcdToSegLUT = VecInit(
+    "b00000011".U(8.W), // 0
+    "b10011111".U(8.W), // 1
+    "b00100101".U(8.W), // 2
+    "b00001101".U(8.W), // 3
+    "b10011001".U(8.W), // 4
+    "b01001001".U(8.W), // 5
+    "b01000001".U(8.W), // 6
+    "b00011111".U(8.W), // 7
+    "b00000001".U(8.W), // 8
+    "b00001001".U(8.W), // 9
+    "b00010001".U(8.W), // A
+    "b11000001".U(8.W), // B
+    "b01100011".U(8.W), // C
+    "b10000101".U(8.W), // D
+    "b01100001".U(8.W), // E
+    "b01110001".U(8.W)  // F
+  )
+
+  io.gpio.seg := segBCD.map(bcd => bcdToSegLUT(bcd(3, 0)))
+
+  object State extends ChiselEnum {
+    val idle, setup, access = Value
+  }
+  object RegAddr {
+    val LED = 0x10002000.U(32.W)
+    val SWITCH = 0x10002004.U(32.W)
+    val SEG = 0x10002008.U(32.W)
+  }
+  val state = RegInit(State.idle)
+
+  when(io.in.psel && !io.in.penable && state === State.idle) {
+    state := State.setup
+  }.elsewhen(io.in.psel && io.in.penable && state === State.setup) {
+    state := State.access
+  }.elsewhen(!io.in.psel) {
+    state := State.idle
+  }
+
+  val rData = WireDefault(0.U(32.W))
+
+  when(state === State.access) {
+    when(io.in.pwrite) {
+      switch(io.in.paddr) {
+        is(RegAddr.LED) {
+          led := io.in.pwdata(15, 0)
+        }
+        is(RegAddr.SEG) {
+          for (i <- 0 until 8) {
+            segBCD(i) := (io.in.pwdata >> i * 4)(3, 0)
+          }
+        }
+      }
+    }.otherwise {
+      switch(io.in.paddr) {
+        is(RegAddr.LED) {
+          rData := Cat(0.U(16.W), led)
+        }
+        is(RegAddr.SWITCH) {
+          rData := Cat(0.U(16.W), io.gpio.in)
+        }
+        is(RegAddr.SEG) {
+          rData := segBCD.zipWithIndex
+            .map { case (s, i) => s(3, 0) << (i * 4) }
+            .reduce(_ | _)
+        }
+      }
+    }
+  }
+
+  io.in.pready := (state === State.access)
+  io.in.pslverr := false.B
+  io.in.prdata := rData
 }
 
-class APBGPIO(address: Seq[AddressSet])(implicit p: Parameters) extends LazyModule {
-  val node = APBSlaveNode(Seq(APBSlavePortParameters(
-    Seq(APBSlaveParameters(
-      address       = address,
-      executable    = true,
-      supportsRead  = true,
-      supportsWrite = true)),
-    beatBytes  = 4)))
+class APBGPIO(address: Seq[AddressSet])(implicit p: Parameters)
+    extends LazyModule {
+  val node = APBSlaveNode(
+    Seq(
+      APBSlavePortParameters(
+        Seq(
+          APBSlaveParameters(
+            address = address,
+            executable = true,
+            supportsRead = true,
+            supportsWrite = true
+          )
+        ),
+        beatBytes = 4
+      )
+    )
+  )
 
   lazy val module = new Impl
   class Impl extends LazyModuleImp(this) {
     val (in, _) = node.in(0)
     val gpio_bundle = IO(new GPIOIO)
 
-    val mgpio = Module(new gpio_top_apb)
+    val mgpio = Module(new gpioChisel)
     mgpio.io.clock := clock
     mgpio.io.reset := reset
     mgpio.io.in <> in
diff --git a/src/device/SPI.scala b/src/device/SPI.scala
index e30997ad..2b2ca053 100644
--- a/src/device/SPI.scala
+++ b/src/device/SPI.scala
@@ -119,7 +119,7 @@ class APBSPI(address: Seq[AddressSet])(implicit p: Parameters)
     val mspiReady = mspi.io.in.pready
     val mspiRData = mspi.io.in.prdata
 
-    val enFastFlash = sys.env.getOrElse("SOC_USE_FAST_FLASH", "false").toBoolean
+    val enFastFlash = Config.useFastFlash
 
     when(in.paddr >= 0x30000000.U && in.paddr < 0x40000000.U && (!enFastFlash).B) {
       mspi.io.in.psel := (!isIdle) && (!isDone) && (!currentCheckBusy)
