+++ b/src/Top.scala
@@ -8,6 +8,7 @@ import freechips.rocketchip.diplomacy.LazyModule
 object Config {
   def hasChipLink: Boolean = false
   def sdramUseAXI: Boolean = true
+  def DelayRatio: Float = sys.env.getOrElse("DELAY_RATIO", "4").toFloat
   def useFastFlash: Boolean = sys.env.getOrElse("USE_FAST_FLASH", "0") == "1"
 }
 
diff --git a/src/amba/APBDelayer.scala b/src/amba/APBDelayer.scala
