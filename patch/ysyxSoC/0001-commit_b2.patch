+uint32_t sdram_read(uint32_t addr){
+  uint16_t row = (addr & 0x000007FB) >> 2;
+  uint16_t bank = (addr & 0x00001800) >> 11;
+  uint16_t col = (addr & 0x03FFE) >> 13;
+
+  return sdram[bank][col][row];
+}
+
+void init_mem() {
