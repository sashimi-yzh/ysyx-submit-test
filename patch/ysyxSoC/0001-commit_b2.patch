+}
+
+extern "C" void flash_read(int32_t addr, int32_t *data) {
+
+    uint32_t temp;
+
+    if((uint32_t)addr >= CONFIG_FLASH && (uint32_t)addr <= FLASH_RIGHT) {
+
+        temp = host_read_f(guest_to_host_flash(addr));
+        // printf("%08x, %08x\n", addr, temp);
+        *data = (int32_t)temp;
+    }
+    else{
+        printf("flash out of bound\n");
+        assert(0);
+    }
+    return;
+}
