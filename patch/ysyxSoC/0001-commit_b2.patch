+    always @ (posedge clk or negedge rst_n)
+        if(!rst_n)
+            sck <= 1'b0;
+        else if(~ce_n)
+            sck <= ~ sck;
+        else if(state != SWITCH)
+            sck <= 1'b0;
+
+    // ce_n logic
+    always @ (posedge clk or negedge rst_n)
+        if(!rst_n)
+            ce_n <= 1'b1;
+        else if(state == SWITCH)
+            ce_n <= 1'b0;
+        else
+            ce_n <= 1'b1;
+
+    always @ (posedge clk or negedge rst_n)
+        if(!rst_n)
+            counter <= 8'b0;
+        else if(sck & ~done)
+            counter <= counter + 1'b1;
+        else if(state != SWITCH)
+            counter <= 8'b0;
+
+    // always @ (posedge clk or negedge rst_n)
+    //     if(!rst_n)
+    //         saddr <= 24'b0;
+    //     else if((state == IDLE) && wr)
+    //         saddr <= addr;
+
+    assign dout     =   (counter < 8)   ?   {3'b0, CMD_AAH[7 - counter]}:
+                        4'b0000;
+
+
+    assign douten   = (~ce_n);
+
+    assign done     = (counter == FINAL_COUNT + 1);
+
+endmodule
