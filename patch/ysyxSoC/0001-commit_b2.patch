diff --git a/csrc/src/sdb/watchpoint.cpp b/csrc/src/sdb/watchpoint.cpp
new file mode 100644
index 00000000..527b764e
--- /dev/null
+++ b/csrc/src/sdb/watchpoint.cpp
@@ -0,0 +1,162 @@
+/***************************************************************************************
