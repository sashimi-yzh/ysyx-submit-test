       UInt(16.W),
-      Some(Seq("block","bank", "row", "col"))
-    )(enReadCall, block.U(8.W),bank.pad(8), row(bank).pad(16), col.pad(16))
+      Some(Seq("block", "bank", "row", "col"))
+    )(enReadCall, block.U(8.W), bank.pad(8), row(bank).pad(16), col.pad(16))
 
     val wData = WireDefault(InvalidValue)
     val enWriteCall = WireDefault(false.B)
@@ -195,7 +233,7 @@ class sdramChiselBlock(block:Int=0) extends RawModule {
     dontTouch(enWriteCall)
     RawClockedVoidFunctionCall(
       "sdram_write",
-      Some(Seq("block","bank", "row", "col", "data", "mask"))
+      Some(Seq("block", "bank", "row", "col", "data", "mask"))
     )(
       io.clk.asClock,
       enWriteCall,
@@ -241,7 +279,6 @@ class sdramChiselBlock(block:Int=0) extends RawModule {
   }
 }
 
