-    val BURST_STOP = "b110".U(3.W)
-    val PRECHARGE = "b010".U(3.W)
-    val REFRESH = "b001".U(3.W)
-    val LOAD_MODE = "b000".U(3.W)
-  }
 
   val cmd = Wire(UInt(3.W))
   dontTouch(cmd)
@@ -153,7 +191,7 @@ class sdramChiselBlock(block:Int=0) extends RawModule {
   withClockAndReset(io.clk.asClock, false.B) {
     when(cmd === CMD.LOAD_MODE) { mode := io.a(11, 0) }
 
