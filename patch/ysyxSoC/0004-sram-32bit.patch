+    if(!rst_n)
+        sck <= 1'b0;
+    else if(~ce_n)
+        sck <= ~ sck;
+    else 
+        sck <= 1'b0;
+
+always @ (posedge clk or negedge rst_n)
+    if(!rst_n)
+        ce_n <= 1'b1;
+    else if(start)
+        ce_n <= 1'b0;
+    else
+        ce_n <= 1'b1;
+
+always @ (posedge clk or negedge rst_n)
+    if(!rst_n)
+        counter <= 8'b0;
+    else if(sck & ~done)
+        counter <= counter + 1'b1;
+    else if(ce_n)
+        counter <= 8'b0;
