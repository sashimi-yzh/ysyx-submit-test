+// Using EBH Command
+module PSRAM_INIT (
+    // External Interface to Quad I/O
+    input   wire            clk,
+    input   wire            rst_n,
+    input                   start,
+    output  wire            done,   
+    output  reg             sck,
+    output  reg             ce_n,
+    output  wire [3:0]      dout,
+    output  wire            douten
