From d66ac6002f41109f73310bec47bfb7e760a93c98 Mon Sep 17 00:00:00 2001
From: Wang Yi Jie <miwyj@mail.scut.edu.cn>
Date: Sun, 1 Feb 2026 16:22:55 +0800
Subject: [PATCH 18/28] modify sdram axi ctrl port width 16->32

---
 perip/sdram/core_sdram_axi4/sdram_axi.v      |  8 ++++----
 perip/sdram/core_sdram_axi4/sdram_axi_core.v |  4 +++-
 perip/sdram/sdram_top_axi.v                  | 14 +++++++-------
 src/Top.scala                                |  4 ++--
 src/amba/APBDelayer.scala                    |  4 ++--
 5 files changed, 18 insertions(+), 16 deletions(-)

diff --git a/perip/sdram/core_sdram_axi4/sdram_axi.v b/perip/sdram/core_sdram_axi4/sdram_axi.v
index d8fe4eda..30bcfac6 100644
--- a/perip/sdram/core_sdram_axi4/sdram_axi.v
+++ b/perip/sdram/core_sdram_axi4/sdram_axi.v
@@ -55,7 +55,7 @@ module sdram_axi
     ,input  [  7:0]  inport_arlen_i
     ,input  [  1:0]  inport_arburst_i
     ,input           inport_rready_i
-    ,input  [ 15:0]  sdram_data_input_i
+    ,input  [ 31:0]  sdram_data_input_i
 
     // Outputs
     ,output          inport_awready_o
@@ -75,10 +75,10 @@ module sdram_axi
     ,output          sdram_ras_o
     ,output          sdram_cas_o
     ,output          sdram_we_o
-    ,output [  1:0]  sdram_dqm_o
+    ,output [  3:0]  sdram_dqm_o
     ,output [ 12:0]  sdram_addr_o
-    ,output [  1:0]  sdram_ba_o
-    ,output [ 15:0]  sdram_data_output_o
+    ,output [  2:0]  sdram_ba_o
+    ,output [ 31:0]  sdram_data_output_o
     ,output          sdram_data_out_en_o
 );
 
diff --git a/perip/sdram/core_sdram_axi4/sdram_axi_core.v b/perip/sdram/core_sdram_axi4/sdram_axi_core.v
index 9a5c1fb7..2e65e086 100644
--- a/perip/sdram/core_sdram_axi4/sdram_axi_core.v
+++ b/perip/sdram/core_sdram_axi4/sdram_axi_core.v
@@ -70,7 +70,9 @@ module sdram_axi_core
 // Key Params
 //-----------------------------------------------------------------
 parameter SDRAM_MHZ              = 50;
-parameter SDRAM_ADDR_W           = 24;
+// NEED modified by passing it from user module!!!
+// parameter SDRAM_ADDR_W           = 24;
+parameter SDRAM_ADDR_W           = 25;
 parameter SDRAM_COL_W            = 9;
 // parameter SDRAM_READ_LATENCY     = 1;
 // NEED modified by passing it from user module!!!
diff --git a/perip/sdram/sdram_top_axi.v b/perip/sdram/sdram_top_axi.v
index 0208f1bd..c6509501 100644
--- a/perip/sdram/sdram_top_axi.v
+++ b/perip/sdram/sdram_top_axi.v
@@ -40,19 +40,19 @@ module sdram_top_axi(
   output        sdram_cas,
   output        sdram_we,
   output [12:0] sdram_a,
-  output [ 1:0] sdram_ba,
-  output [ 1:0] sdram_dqm,
-  inout  [15:0] sdram_dq
+  output [ 2:0] sdram_ba,
+  output [ 3:0] sdram_dqm,
+  inout  [31:0] sdram_dq
 );
 
   wire sdram_dout_en;
-  wire [15:0] sdram_dout;
-  assign sdram_dq = sdram_dout_en ? sdram_dout : 16'bz;
+  wire [31:0] sdram_dout;
+  assign sdram_dq = sdram_dout_en ? sdram_dout : 32'bz;
   sdram_axi #(
     .SDRAM_MHZ(100),
-    .SDRAM_ADDR_W(24),
+    .SDRAM_ADDR_W(25),
     .SDRAM_COL_W(9),
-    .SDRAM_READ_LATENCY(2)
+    .SDRAM_READ_LATENCY(1)
   ) u_sdram_axi(
     .clk_i(clock),
     .rst_i(reset),
diff --git a/src/Top.scala b/src/Top.scala
index cb82ca74..1b346ccd 100644
--- a/src/Top.scala
+++ b/src/Top.scala
@@ -7,8 +7,8 @@ import freechips.rocketchip.diplomacy.LazyModule
 
 object Config {
   def hasChipLink: Boolean = false
-  def sdramUseAXI: Boolean = false
-  def useFastFlash: Boolean = true//sys.env.getOrElse("USE_FAST_FLASH", "0") == "1"
+  def sdramUseAXI: Boolean = true
+  def useFastFlash: Boolean = sys.env.getOrElse("USE_FAST_FLASH", "0") == "1"
 }
 
 class ysyxSoCTop extends Module {
diff --git a/src/amba/APBDelayer.scala b/src/amba/APBDelayer.scala
index 2b09726a..e6e87e06 100644
--- a/src/amba/APBDelayer.scala
+++ b/src/amba/APBDelayer.scala
@@ -52,7 +52,7 @@ class APBDelayerChisel extends Module {
   // we should delay this response to t1' such that (t1 - t0) * ratio = (t1' - t0)
   //
 
-  val ratio = sys.env.getOrElse("APB_DELAY_RATIO", "6").toFloat
+  val ratio = sys.env.getOrElse("APB_DELAY_RATIO", "4").toFloat
   println(s"APB Delayer ratio: $ratio")
   val scale = 32;
 
@@ -89,7 +89,7 @@ class APBDelayerChisel extends Module {
   io.out.penable := io.in.penable && (state === State.waitOutReady)
 
   // payload connect directly
-  io.out.pwrite := io.in.pwrite
+  io.out.pwrite := io.in.pwrite  // && io.out.psel // seems no need??
   io.out.paddr := io.in.paddr
   io.out.pprot := io.in.pprot
   io.out.pwdata := io.in.pwdata
-- 
