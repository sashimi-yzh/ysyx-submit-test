+    case (xip_state)
+      STATE_IDLE: begin
+        if(in_paddr >= flash_addr_start && in_paddr <= flash_addr_end && in_pwrite==0 && in_psel==1 && in_penable==1) 
+        //  if(in_paddr != paddr) begin
+            is_flash_access <= 1;
+        counter <= 0;
+        //  end
+        wb_adr_i <= in_paddr[4:0];
+        wb_dat_i <= in_pwdata;
+        in_prdata <= wb_dat_o;
+        wb_sel_i <= in_pstrb;
+        wb_we_i <= in_pwrite;
+        wb_stb_i <= in_psel;
+        wb_cyc_i <= in_penable;
+        if(in_paddr >= flash_addr_start && in_paddr <= flash_addr_end) in_pready <= wb_ack_o;
+        else in_pready <= 0;
+        in_pslverr <= wb_err_o;
+        spi_irq_out <= wb_int_o;
+        flag <= 0;
+        
+      end
+      
+      STATE_SET_DIV: begin
+        paddr <= in_paddr;
+        wb_sel_i <= 4'hf;
+        wb_we_i <= 1;
+        wb_stb_i <= 1;
+        wb_cyc_i <= 1;
+        
+        wb_adr_i <= REG_SPI_DIV; 
+        wb_dat_i <= 32'd2;
+        is_flash_access <= 0;
+        wb_we_i <= 1;
+      end
+      
+      STATE_SET_SS: begin
+        wb_sel_i <= 4'hf;
+        wb_we_i <= 1;
+        wb_stb_i <= 1;
+        wb_cyc_i <= 1;
+        
+        wb_adr_i <= REG_SPI_SS; 
+        wb_dat_i <= 32'd1;
+      end
+
+      STATE_SET_TX: begin
+        wb_sel_i <= 4'hf;
+        wb_we_i <= 1;
+        wb_stb_i <= 1;
+        wb_cyc_i <= 1;
+        wb_adr_i <= REG_SPI_TX; 
+        wb_dat_i <= (paddr & 32'h00FFFFFF) | CMD_READ;
+      end
+      
+      STATE_SET_CTRL: begin
+        wb_sel_i <= 4'hf;
+        wb_we_i <= 1;
+        wb_stb_i <= 1;
+        wb_cyc_i <= 1;
+        wb_adr_i <= REG_SPI_CTRL; 
+        wb_dat_i[7:0] <= 8'h40;
+        wb_dat_i[8] <= 1'b1;
+        wb_dat_i[9] <= 1'b1;
+        wb_dat_i[31:10] <= 0;
+        
+      end
+
+      STATE_GET_CTRL: begin
+        wb_sel_i <= 4'hf;
+        wb_we_i <= 0;
+        wb_stb_i <= 0;
+        wb_cyc_i <= 0;
+        done <= ~wb_dat_o[8];
+        wb_we_i <= 0;
+      end
+
+      STATE_GET_RX0: begin
+        done <= 0;
+        wb_adr_i <= REG_SPI_RX0; 
+        data[31:0] <= wb_dat_o;
+      end
+
+      STATE_GET_RX1: begin
+        
+        wb_adr_i <= REG_SPI_RX1; 
+        data[63:32] <= wb_dat_o;
+      end
+
+      STATE_GET_SS: begin
+        wb_sel_i <= 4'hf;
+        wb_we_i <= 1;
+        wb_stb_i <= 1;
+        wb_cyc_i <= 1;
+        wb_adr_i <= REG_SPI_SS; 
+        wb_dat_i <= 32'd0;
+        
+        
+        
+      end
+      STATE_GET_DONE: begin
+        wb_adr_i <= in_paddr[4:0];
+        wb_dat_i <= in_pwdata;
+        in_prdata <= wb_dat_o;
+        wb_sel_i <= in_pstrb;
+        wb_we_i <= 0;
+        wb_stb_i <= 0;
+        wb_cyc_i <= 0;
+
+        if(in_pready == 1 && flag == 1) in_pready <= 0;
+        else if(flag == 0)begin
+          in_pready <= 1;
+          flag <= 1;
+        end
+        in_prdata <= {tmp[7:0],tmp[15:8],tmp[23:16],tmp[31:24]};
+        
+      end
+      default: begin
+        ;
+      end
+    endcase
+  end
+end
+
+
+always @(*) begin
+    case (xip_state)
+      STATE_IDLE: begin
+        if (is_flash_access) begin
+          xip_state_next = STATE_SET_DIV;
+        end
+        else xip_state_next = STATE_IDLE;
+        
+      end
+      
+      STATE_SET_DIV: begin
+        if(counter == `DELAY*1)  
+          xip_state_next = STATE_SET_SS;
+        else if(in_pwrite==1) 
+          xip_state_next = STATE_IDLE;
+        else 
+          xip_state_next = STATE_SET_DIV;
+      end
+      
+      STATE_SET_SS: begin
+        if(counter == `DELAY*2)  
+          xip_state_next = STATE_SET_TX;
+        else
+          xip_state_next = STATE_SET_SS;
+        
+      end
+
+      STATE_SET_TX: begin
+        if(counter == `DELAY*3)  
+          xip_state_next = STATE_SET_CTRL;
+        else
+          xip_state_next = STATE_SET_TX;
+        
+      end
+      
+      STATE_SET_CTRL: begin
+        if(counter == `DELAY*4)  
+          xip_state_next = STATE_GET_CTRL;
+        else
+          xip_state_next = STATE_SET_CTRL;
+        
+      end
+
+      STATE_GET_CTRL: begin
+        if (done) begin
+          xip_state_next = STATE_GET_RX0;
+        end
+        else xip_state_next = STATE_GET_CTRL;
+      end
+
+      STATE_GET_RX0: begin
+        if(counter == `DELAY*1)  
+          xip_state_next = STATE_GET_RX1;
+        else
+          xip_state_next = STATE_GET_RX0;
+        
+      end
+
+      STATE_GET_RX1: begin
+        if(counter == `DELAY*2)  
+          xip_state_next = STATE_GET_SS;
+        else
+          xip_state_next = STATE_GET_RX1;
+        
+      end
+
+      STATE_GET_SS: begin
+        if(counter == `DELAY*3)  
+          xip_state_next = STATE_GET_DONE;
+        else
+          xip_state_next = STATE_GET_SS;
+        
+      end
+
+      STATE_GET_DONE: begin
+        if(counter == `DELAY*4)  
+          xip_state_next = STATE_IDLE;
+        else
+          xip_state_next = STATE_GET_DONE;
+        
+      end
+
+      default: begin
+        xip_state_next = STATE_IDLE;
+      end
+    endcase
+  end
+
 
-endmodule
+endmodule
