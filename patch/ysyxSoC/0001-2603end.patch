diff --git a/perip/bitrev/bitrev.v b/perip/bitrev/bitrev.v
index f1c3b363..5833509d 100644
--- a/perip/bitrev/bitrev.v
+++ b/perip/bitrev/bitrev.v
@@ -2,7 +2,42 @@ module bitrev (
   input  sck,
   input  ss,
   input  mosi,
-  output miso
+  output reg miso
 );
-  assign miso = 1'b1;
+  //assign miso = 1'b1;
+
+// 内部寄存器
+reg [7:0] shift_in;    // 输入移位寄存器
+reg [4:0] bit_count;   // 位计数器
+reg       active;      // 传输活跃标志
+
+// 异步复位，同步逻辑
+always @(posedge sck) begin
+    // 片选有效时开始传输
+    if (!ss) begin
+            // 正在传输中
+            if (bit_count < 5'd8) begin
+                // 前8个时钟：接收数据
+                shift_in <= {shift_in[6:0], mosi};
+                miso <= 1'b1;  // 接收阶段保持高电平
+                bit_count <= bit_count + 1;
+            end else if (bit_count < 5'd16) begin
+                // 后8个时钟：发送位翻转后的数据
+                miso <= shift_in[bit_count-8];
+                bit_count <= bit_count + 1;
+            end
+            else begin
+                bit_count <= 1;
+                shift_in <= {shift_in[6:0], mosi};
+            end
+    end else begin
+        // 片选无效，重置状态
+        active <= 1'b0;
+        bit_count <= 5'd1;
+        miso <= 1'b1;      // 空闲时MISO为高电平
+        shift_in <= 0;
+    end
+end
+
+
 endmodule
