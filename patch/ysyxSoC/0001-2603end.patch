+
+    
+    // Next state logic
+    always @(*) begin        
+        if (ce_n) begin
+            // Chip disabled, return to idle
+            next_state = STATE_IDLE;
+        end else begin
+            case (state)
+                STATE_IDLE: begin
+                    if (!ce_n) begin
+                        next_state = STATE_CMD;
+                    end
+                    else begin
+                      next_state = STATE_IDLE;
+                    end
+                end
+                
+                STATE_CMD: begin
