diff --git a/perip/amba/apb_delayer.v b/perip/amba/apb_delayer.v
index c0d20764..4ec73040 100644
--- a/perip/amba/apb_delayer.v
+++ b/perip/amba/apb_delayer.v
@@ -1,4 +1,204 @@
-module apb_delayer(
+module apb_delayer #(
+    parameter CPU_FREQ_MHZ  = 550,
+    parameter DEV_FREQ_MHZ  = 100,
+    parameter SCALE_FACTOR  = 512       // 必须是2的幂，便于用移位代替除法
+)(
+    input         clock,
+    input         reset,
+
+    // 上游接口 (CPU侧，延迟模块作为APB slave)
+    input  [31:0] in_paddr,
+    input         in_psel,
+    input         in_penable,
+    input  [2:0]  in_pprot,
+    input         in_pwrite,
+    input  [31:0] in_pwdata,
+    input  [3:0]  in_pstrb,
+    output reg         in_pready,
+    output reg  [31:0] in_prdata,
+    output reg         in_pslverr,
+
+    // 下游接口 (设备侧，延迟模块作为APB master)
+    output [31:0] out_paddr,
+    output        out_psel,
+    output        out_penable,
+    output [2:0]  out_pprot,
+    output        out_pwrite,
+    output [31:0] out_pwdata,
+    output [3:0]  out_pstrb,
+    input         out_pready,
+    input  [31:0] out_prdata,
+    input         out_pslverr
+);
+
+    // =========================================================================
+    // 延迟计算原理
+    // =========================================================================
+    // 频率比 r = CPU_FREQ / DEV_FREQ (例: 550/100 = 5.5)
+    // 放大增量 INC = floor(r * s) = floor(CPU_FREQ * SCALE_FACTOR / DEV_FREQ)
+    //   例: floor(550 * 512 / 100) = 2816
+    //
+    // 设备侧事务花费 k 个周期 (从APB SETUP到pready)
+    // 在设备工作期间, 累加器每周期 += INC, 最终 accum = k * INC
+    // CPU侧应等待的总周期: total = accum >> SCALE_SHIFT ≈ k * r
+    // 已经经过 k 个周期, 还需额外等待: extra = total - k
+    //
+    // 验证 (r=5.5, s=512, k=6):
+    //   INC = 2816, accum = 6*2816 = 16896
+    //   total = 16896 >> 9 = 33
+    //   extra = 33 - 6 = 27
+    //   从t0算起总共: 6 + 27 = 33 个CPU周期
+    //   理想值: 6 * 5.5 = 33 ✓
+    //
+    // 验证 (r=5.5, s=512, k=10):
+    //   accum = 10*2816 = 28160
+    //   total = 28160 >> 9 = 55
+    //   extra = 55 - 10 = 45
+    //   理想值: 10 * 5.5 = 55 ✓
+    // =========================================================================
+
+    localparam integer INC_VALUE   = (CPU_FREQ_MHZ * SCALE_FACTOR) / DEV_FREQ_MHZ;
+    localparam integer SCALE_SHIFT = $clog2(SCALE_FACTOR);
+
+    // =========================================================================
+    // 状态定义
+    // =========================================================================
+    localparam [2:0] ST_IDLE    = 3'd0;  // 空闲, 等待事务
+    localparam [2:0] ST_FORWARD = 3'd1;  // 透传给设备, 等待pready
+    localparam [2:0] ST_WAIT    = 3'd2;  // 额外延迟等待
+    localparam [2:0] ST_SKIP    = 3'd3;  // 向上游返回pready
+    localparam [2:0] ST_DONE    = 3'd4;  // 结束
+
+    reg [2:0] state;
+
+    reg [31:0] accum;          // 放大累加器: k * INC_VALUE
+    reg [15:0] dev_cycles;     // 设备侧周期数 k
+    reg [31:0] wait_cnt;       // 额外等待计数器
+
+    reg [31:0] saved_prdata;
+    reg        saved_pslverr;
+
+    // =========================================================================
+    // 下游APB信号: 在IDLE/FORWARD阶段透传, 其余阶段撤销
+    // =========================================================================
+    wire fwd_active = (state == ST_IDLE) || (state == ST_FORWARD);
+
+    assign out_paddr   = fwd_active ? in_paddr   : 32'd0;
+    assign out_psel    = fwd_active ? in_psel     : 1'b0;
+    assign out_penable = fwd_active ? in_penable  : 1'b0;
+    assign out_pprot   = fwd_active ? in_pprot    : 3'd0;
+    assign out_pwrite  = fwd_active ? in_pwrite   : 1'b0;
+    assign out_pwdata  = fwd_active ? in_pwdata   : 32'd0;
+    assign out_pstrb   = fwd_active ? in_pstrb    : 4'd0;
+
+    // =========================================================================
+    // 组合逻辑: 设备完成时计算延迟
+    // =========================================================================
+    wire [31:0] accum_final  = accum + INC_VALUE[31:0];       // 含当前周期的累加
+    wire [31:0] total_cpu    = accum_final >> SCALE_SHIFT;    // CPU应等待的总周期
+    wire [31:0] k_plus1      = {16'd0, dev_cycles} + 32'd1;  // 当前周期的k
+    // DONE状态占1个周期, 也算入等待, 所以额外等待要再减1
+    wire [31:0] extra_delay  = (total_cpu > k_plus1 + 32'd1) ?
+                               (total_cpu - k_plus1 - 32'd1) : 32'd0;
+
+    // =========================================================================
+    // 主状态机 (时序逻辑)
+    // =========================================================================
+    always @(posedge clock) begin
+        if (reset) begin
+            state         <= ST_IDLE;
+            accum         <= 32'd0;
+            dev_cycles    <= 16'd0;
+            wait_cnt      <= 32'd0;
+            saved_prdata  <= 32'd0;
+            saved_pslverr <= 1'b0;
+            in_pready     <= 1'b0;
+            in_prdata     <= 32'd0;
+            in_pslverr    <= 1'b0;
+        end else begin
+            case (state)
+                // ---------------------------------------------------------
+                // IDLE: 等待APB事务的SETUP阶段
+                // ---------------------------------------------------------
+                ST_IDLE: begin
+                    in_pready  <= 1'b0;
+                    in_pslverr <= 1'b0;
+
+                    if (in_psel && !in_penable) begin
+                        // 检测到SETUP阶段, 开始第1个设备周期
+                        accum      <= INC_VALUE[31:0];
+                        dev_cycles <= 16'd1;
+                        state      <= ST_FORWARD;
+                    end
+                end
+
+                // ---------------------------------------------------------
+                // FORWARD: 透传APB信号, 等待设备完成
+                // ---------------------------------------------------------
+                ST_FORWARD: begin
+                    in_pready <= 1'b0;
+
+                    // 每个周期累加
+                    accum      <= accum + INC_VALUE[31:0];
+                    dev_cycles <= dev_cycles + 16'd1;
+
+                    // 检测设备完成 (ACCESS阶段: penable=1 && pready=1)
+                    if (in_penable && out_pready) begin
+                        saved_prdata  <= out_prdata;
+                        saved_pslverr <= out_pslverr;
+
+                        if (extra_delay == 32'd0) begin
+                            state <= ST_DONE;
+                        end else begin
+                            wait_cnt <= extra_delay;
+                            state    <= ST_WAIT;
+                        end
+                    end
+                end
+
+                // ---------------------------------------------------------
+                // WAIT: 消耗额外延迟周期
+                // ---------------------------------------------------------
+                ST_WAIT: begin
+                    in_pready <= 1'b0;
+                    if (wait_cnt <= 32'd1) begin
+                        state <= ST_SKIP;
+                    end else begin
+                        wait_cnt <= wait_cnt - 32'd1;
+                    end
+                end
+
+                // ---------------------------------------------------------
+                // DONE: 向上游返回pready, 完成事务
+                // ---------------------------------------------------------
+                ST_SKIP: begin
+                    in_pready  <= 1'b1;
+                    in_prdata  <= saved_prdata;
+                    in_pslverr <= saved_pslverr;
+                    state      <= ST_DONE;
+                end
+
+                ST_DONE: begin
+                    in_pready  <= 1'b0;
+                    state      <= ST_IDLE;
+                end
+
+
+
+                default: begin
+                    state <= ST_IDLE;
+                end
+            endcase
+        end
+    end
+
+endmodule
+
+/*module apb_delayer#(
+    parameter CPU_FREQ_MHZ = 550,      // CPU频率（单位MHz）
+    parameter DEV_FREQ_MHZ = 100,      // 设备频率（单位MHz）
