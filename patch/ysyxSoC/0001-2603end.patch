+module sdram_word(
+  input        clk,
+  input        cke,   //时钟使能
+  input        cs,    //片选有效
+  input        ras,
+  input        cas,
+  input        we,
+  input [12:0] a,     //地址信号
+  input [ 1:0] ba,    //储存阵列
+  input [ 3:0] dqm,   //数据掩码
+  inout [31:0] dq     //数据信号
+);
+
+sdram_single u1_high(
+  .clk(clk),
+  .cke(cke),   //时钟使能
+  .cs(cs),    //片选有效
+  .ras(ras),
+  .cas(cas),
+  .we(we),
+  .a(a[12:0]),     //地址信号
+  .ba(ba),    //储存阵列
+  .dqm(dqm[3:2]),   //数据掩码
+  .dq(dq[31:16])     //数据信号
+);
+
+sdram_single u1_low(
+  .clk(clk),
+  .cke(cke),   //时钟使能
+  .cs(cs),    //片选有效
+  .ras(ras),
+  .cas(cas),
+  .we(we),
+  .a(a[12:0]),     //地址信号
+  .ba(ba),    //储存阵列
+  .dqm(dqm[1:0]),   //数据掩码
+  .dq(dq[15:0])     //数据信号
+);
+
+endmodule
