+                            next_state = STATE_DUMMY;
+                        end else if (is_write_op) begin
+                            next_state = STATE_WRITE;
+                        end else begin
+                            next_state = STATE_IDLE;
+                        end
+                    end
+                    else begin 
+                      next_state = STATE_ADDR;
+                    end
+                end
+                
+                STATE_DUMMY: begin
+                    if (counter == 20) begin
+                        next_state = STATE_READ;
+                    end
+                    else begin
+                      next_state = STATE_DUMMY;
+                    end
+                end
+                
+                STATE_READ: begin
+                    // Continue reading until ce_n goes high
+                    // In a real implementation, there might be a byte count limit
+                    next_state = STATE_READ;
+                    
+                end
+                
+                STATE_WRITE: begin
+                    // Continue writing until ce_n goes high
+                    // In a real implementation, there might be a byte count limit
+                    next_state = STATE_WRITE;
+                end
+                default:next_state = STATE_IDLE;
+            endcase
+        end
+    end
+    
+    // Output enable control
+    always @(*) begin
+        case (state)
+            STATE_IDLE:   dio_oe = 4'b0000; // Input for command detection
+            STATE_CMD:    dio_oe = 4'b0000; // Input for command bits (SIO0)
+            STATE_ADDR:   dio_oe = 4'b0000; // Input for address nybbles
+            STATE_DUMMY:  dio_oe = 4'b0000; // Input during dummy cycles
+            STATE_READ:   dio_oe = 4'b1111; // Output for read data
+            STATE_WRITE:  dio_oe = 4'b0000; // Input for write data
+            default:      dio_oe = 4'b0000;
+        endcase
+    end
+
+endmodule
