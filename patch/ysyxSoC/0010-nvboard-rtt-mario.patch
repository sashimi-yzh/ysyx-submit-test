@@ -12,4 +12,10 @@ externalPins_gpio_seg_7 (SEG7A, SEG7B, SEG7C, SEG7D, SEG7E, SEG7F, SEG7G, DEC7P)
 externalPins_uart_tx UART_TX
 externalPins_uart_rx UART_RX
