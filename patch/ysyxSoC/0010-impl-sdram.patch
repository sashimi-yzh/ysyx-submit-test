+// MT48LC16M16A2
+//  16 Meg x 16
+// Row addressing: 8K A[12:0]
+// Bank addressing: 4 B[1:0]
+// Column addressing: 512 A[8:0]
 class sdramChisel extends RawModule {
   val io = IO(Flipped(new SDRAMIO))
+  val dout = WireDefault(0.U(16.W))
+  val dout_en = WireDefault(false.B)
+  val di = TriStateInBuf(io.dq, dout, dout_en)
+
+  dontTouch(io)
+
+  val InvalidValue = "hcccc".U(16.W)
+
+  object CMD {
+    val NOP = "b111".U(3.W)
+    val ACTIVE = "b011".U(3.W)
+    val READ = "b101".U(3.W)
+    val WRITE = "b100".U(3.W)
+    val BURST_STOP = "b110".U(3.W)
+    val PRECHARGE = "b010".U(3.W)
+    val REFRESH = "b001".U(3.W)
+    val LOAD_MODE = "b000".U(3.W)
+  }
+
+  val cmd = Wire(UInt(3.W))
+  dontTouch(cmd)
+  cmd := Mux(io.cs === false.B, io.ras ## io.cas ## io.we, CMD.NOP)
+
+  val mode = withClock(io.clk.asClock) { Reg(UInt(12.W)) }
+  // TODO: handle Full Page mode
+  val burstLength = WireInit(1.U << mode(2, 0))
+  val burstType = WireInit(mode(3))
+  val casLatency = WireInit(mode(6, 4) - 1.U)
+  val operatingMode = WireInit(mode(8, 7))
+  val writeBurstMode = WireInit(mode(9))
+
+  object State extends ChiselEnum {
+    val idle, casWait, sendRData, recvWData = Value
+  }
+
+  withClockAndReset(io.clk.asClock, false.B) {
+    when(cmd === CMD.LOAD_MODE) { mode := io.a(11, 0) }
+
+    val row = Reg(UInt(13.W))
+    val bank = Reg(UInt(2.W))
+    val col = Reg(UInt(9.W))
+
+    val state = Reg(State())
+
+    when(cmd === CMD.ACTIVE) {
+      row := io.a(12, 0)
+      bank := io.ba
+    }
+    when(cmd === CMD.READ || cmd === CMD.WRITE) {
+      col := io.a(8, 0)
+      bank := io.ba
+    }
+
+    val enReadCall = WireDefault(false.B)
+    dontTouch(enReadCall)
+
+    // val rdataReg = Wire(UInt(16.W))
+    // dontTouch(rdataReg)
+    // when(enReadCall){
+    //   rdataReg := MuxLookup(col, 0.U)(Seq(
+    //     0.U -> "h1234".U(16.W),
+    //     1.U -> "h5678".U(16.W),
+    //     2.U -> "habcd".U(16.W),
+    //     3.U -> "hef01".U(16.W)
+    //   ))
+    // } .otherwise {
+    //   rdataReg := 0.U(16.W)
+    // }
+    val rData = RawUnclockedNonVoidFunctionCall(
+      "sdram_read",
+      UInt(16.W),
+      Some(Seq("bank", "row", "col"))
+    )(enReadCall, bank.pad(8), row.pad(16), col.pad(16))
+
+    val wData = WireDefault(InvalidValue)
+    val enWriteCall = WireDefault(false.B)
+    val wCol = Wire(UInt(16.W))
+    dontTouch(wCol)
+    val wBank = Wire(UInt(2.W))
+    dontTouch(wBank)
+    val inCount = Wire(UInt(3.W))
+    // TODO: support burst write
+    inCount := Mux(state === State.recvWData, 1.U, 0.U)
+
+    wCol := io.a(8, 0).pad(16) + inCount.pad(16)
+    wBank := io.ba
+
+    dontTouch(enWriteCall)
+    RawClockedVoidFunctionCall(
+      "sdram_write",
+      Some(Seq("bank", "row", "col", "data", "mask"))
+    )(
+      io.clk.asClock,
+      enWriteCall,
+      wBank.pad(8),
+      row.pad(16),
+      wCol,
+      wData.pad(16),
+      io.dqm.pad(8)
+    )
+
+    val casCount = Reg(UInt(3.W))
+    val outCount = Reg(UInt(3.W))
+    when(cmd === CMD.READ) {
+      state := State.casWait
+      casCount := 0.U
+    }.elsewhen(cmd === CMD.WRITE) {
+      state := State.recvWData
+      wData := di
+      enWriteCall := true.B
+    }.elsewhen(state === State.recvWData) {
+      wData := di
+      enWriteCall := true.B
+      state := State.idle
+    }.elsewhen(state === State.casWait) {
+      when(casCount === (casLatency - 1.U)) {
+        state := State.sendRData
+      }.otherwise {
+        casCount := casCount + 1.U
+      }
+    }.elsewhen(state === State.sendRData) {
+      dout := rData
+      enReadCall := true.B
+      dout_en := true.B
+      when(outCount === (burstLength - 1.U)) {
+        state := State.idle
+        outCount := 0.U
+      }.otherwise {
+        outCount := outCount + 1.U
+        col := col + 1.U
+      }
+    }
+  }
 }
 
