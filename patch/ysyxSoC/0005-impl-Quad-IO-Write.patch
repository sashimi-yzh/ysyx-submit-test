From 31fbf92af269c90dfdcd9003ae12f60eea43987a Mon Sep 17 00:00:00 2001
From: Wang Yi Jie <miwyj@mail.scut.edu.cn>
Date: Wed, 21 Jan 2026 19:14:29 +0800
Subject: [PATCH 05/28] impl Quad IO Write

---
 src/device/PSRAM.scala | 46 ++++++++++++++++++++++++++++++++++++------
 1 file changed, 40 insertions(+), 6 deletions(-)

diff --git a/src/device/PSRAM.scala b/src/device/PSRAM.scala
index 6c7d22cd..c3efdbe0 100644
--- a/src/device/PSRAM.scala
+++ b/src/device/PSRAM.scala
@@ -45,7 +45,7 @@ class psramChisel extends RawModule {
   }
 
   object State extends ChiselEnum {
-    val readCmd, readAddr, waitDelay, sendData = Value
+    val readCmd, readAddr, waitDelay, sendRData, readWData = Value
   }
 
   withClockAndReset(io.sck.asClock, io.ce_n) {
@@ -56,10 +56,12 @@ class psramChisel extends RawModule {
     val addrReg = RegInit(0.U(24.W))
 
     val isCmdRead = cmdReg === CMD.QIO_READ
+    val isCmdWrite = cmdReg === CMD.QIO_WRITE
 
     val readDelay = 6.U
 
     val rdData = RegInit(0.U(32.W))
+    val wrDataRev = RegInit(0.U(32.W))
 
     switch(state) {
       is(State.readCmd) {
@@ -77,8 +79,8 @@ class psramChisel extends RawModule {
           when(isCmdRead) {
             state := State.waitDelay
           }.otherwise {
-            state := State.readCmd
-            // TODO: handle write
+            state := State.readWData
+            wrDataRev := 0.U
           }
           cnt := 0.U
         }.otherwise {
@@ -90,7 +92,7 @@ class psramChisel extends RawModule {
         // wait 6 cycles and then
         // begin to send data at next cycle
         when(cnt === readDelay - 1.U + 1.U) {
-          state := State.sendData
+          state := State.sendRData
           cnt := 0.U
           rdData := RawUnclockedNonVoidFunctionCall("psram_read", UInt(32.W))(
             true.B,
@@ -100,7 +102,7 @@ class psramChisel extends RawModule {
           cnt := cnt + 1.U
         }
       }
-      is(State.sendData) {
+      is(State.sendRData) {
         when(cnt === 7.U) {
           state := State.readCmd
           cnt := 0.U
@@ -112,6 +114,7 @@ class psramChisel extends RawModule {
         // data[31:0] = {byte3, byte2, byte1, byte0}
         // send order:
         // byte0 -> byte1 -> byte2 -> byte3
+        // di: [7:4][3:0] -> [15:12][11:8] ...
         //
         // every 2 cycles, send 1 byte
         // first cycle(cnt even) send hi 2 bits
@@ -122,8 +125,39 @@ class psramChisel extends RawModule {
         val curByte = (rdData >> curByteOffset)(7, 0)
         dout := Mux(isSendByteLow, curByte(3, 0), curByte(7, 4))
       }
+      is(State.readWData) {
+        val nxtData = Wire(UInt(32.W))
+        when(cnt === 7.U) {
+          state := State.readCmd
+          cnt := 0.U
+          RawClockedVoidFunctionCall("psram_write")(
+            io.sck.asClock,
+            (!io.ce_n),
+            Cat(0.U(8.W), addrReg),
+            nxtData
+          )
+        }.otherwise {
+          cnt := cnt + 1.U
+        }
+        // receive byte0 -> byte1 -> byte2 -> byte3
+        // di: [7:4][3:0] -> [15:12][11:8] ...
+        //
+        // push di at MSB side
+        //
+        // every 2 cycles, receive 1 byte
+        //
+        val isRecvByteLow = cnt(0)
+        val curByteOffset = cnt(2, 1) << 3
+        nxtData := Mux(
+          isRecvByteLow,
+          wrDataRev | (Cat(0.U(4.W), di) << curByteOffset),
+          wrDataRev | (Cat(di, 0.U(4.W)) << curByteOffset)
+        )
+
+        wrDataRev := nxtData
+      }
     }
-    dout_en := (state === State.sendData)
+    dout_en := (state === State.sendRData)
   }
 }
 
