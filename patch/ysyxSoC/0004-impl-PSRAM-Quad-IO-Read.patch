@@ -30,17 +33,117 @@ class psram extends BlackBox {
 
 class psramChisel extends RawModule {
   val io = IO(Flipped(new QSPIIO))
-  val di = TriStateInBuf(io.dio, 0.U, false.B) // change this if you need
+
+  val dout = WireDefault(0.U(4.W))
+  val dout_en = WireDefault(false.B)
+
+  val di = TriStateInBuf(io.dio, dout, dout_en)
+
+  object CMD {
+    val QIO_READ = "hEB".U(8.W)
+    val QIO_WRITE = "h38".U(8.W)
+  }
+
+  object State extends ChiselEnum {
+    val readCmd, readAddr, waitDelay, sendData = Value
+  }
+
+  withClockAndReset(io.sck.asClock, io.ce_n) {
+    val state = RegInit(State.readCmd)
+    val cnt = RegInit(0.U(3.W))
+    val cmdReg = RegInit(0.U(8.W))
+
+    val addrReg = RegInit(0.U(24.W))
+
+    val isCmdRead = cmdReg === CMD.QIO_READ
+
+    val readDelay = 6.U
+
+    val rdData = RegInit(0.U(32.W))
+
+    switch(state) {
+      is(State.readCmd) {
+        when(cnt === 7.U) {
+          state := State.readAddr
+          cnt := 0.U
+        }.otherwise {
+          cnt := cnt + 1.U
+        }
+        cmdReg := Cat(cmdReg(6, 0), di(0))
+      }
+      is(State.readAddr) {
+        // 24b = 6*4
+        when(cnt === 5.U) {
+          when(isCmdRead) {
+            state := State.waitDelay
+          }.otherwise {
+            state := State.readCmd
+            // TODO: handle write
+          }
+          cnt := 0.U
+        }.otherwise {
+          cnt := cnt + 1.U
+        }
+        addrReg := Cat(addrReg(19, 0), di)
+      }
+      is(State.waitDelay) {
+        // wait 6 cycles and then
+        // begin to send data at next cycle
+        when(cnt === readDelay - 1.U + 1.U) {
+          state := State.sendData
+          cnt := 0.U
+          rdData := RawUnclockedNonVoidFunctionCall("psram_read", UInt(32.W))(
+            true.B,
+            Cat(0.U(8.W), addrReg)
+          )
+        }.otherwise {
+          cnt := cnt + 1.U
+        }
+      }
+      is(State.sendData) {
+        when(cnt === 7.U) {
+          state := State.readCmd
+          cnt := 0.U
+        }.otherwise {
+          cnt := cnt + 1.U
+        }
+
+        //
+        // data[31:0] = {byte3, byte2, byte1, byte0}
+        // send order:
+        // byte0 -> byte1 -> byte2 -> byte3
+        //
+        // every 2 cycles, send 1 byte
+        // first cycle(cnt even) send hi 2 bits
+        // second cycle(cnt odd) send lo 2 bits
+        //
+        val isSendByteLow = cnt(0)
+        val curByteOffset = cnt(2, 1) << 3
+        val curByte = (rdData >> curByteOffset)(7, 0)
+        dout := Mux(isSendByteLow, curByte(3, 0), curByte(7, 4))
+      }
+    }
+    dout_en := (state === State.sendData)
+  }
 }
 
