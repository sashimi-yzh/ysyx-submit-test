mainmenu "NPC Configuration NPC"

choice
  prompt "Running mode"
  default MODE_SYSTEM

config MODE_SYSTEM
  bool "System mode"
  help
    Support full-system functionality, including privileged instructions, MMU and devices.
endchoice

menu "Build Options"
choice
  prompt "Compiler"
  default CC_GCC
config CC_GCC
  bool "gcc"
config CC_GPP
  bool "g++"
config CC_CLANG
  bool "clang"
endchoice

config CC
  string
  default "gcc" if CC_GCC
  default "g++" if CC_GPP
  default "clang" if CC_CLANG
  default "none"

choice
  prompt "Optimization Level"
  default CC_O2
config CC_O0
  bool "O0"
config CC_O1
  bool "O1"
config CC_O2
  bool "O2"
config CC_O3
  bool "O3"
endchoice

config CC_OPT
  string
  default "-O0" if CC_O0
  default "-O1" if CC_O1
  default "-O2" if CC_O2
  default "-O3" if CC_O3
  default "none"


config CC_DEBUG
  bool "Enable debug information"
  default y

config CC_ASAN
  depends on MODE_SYSTEM
  bool "Enable address sanitizer"
  default n

endmenu

menu "Testing and Debugging"

choice
  prompt "Running Mode"
  default SOC
config SOC
  bool "enable soc simulation"
config NPC
  bool "enable npc simulation"
endchoice

config NOBOOTLOADER
  depends on SOC
  bool "Disable bootloader"
  default n

config NVBOARD
  depends on SOC && !NOBOOTLOADER
  bool "enable nvboard"
  default n

config ICARUS
  depends on NPC
  bool "enable icarus verilog"
  default n

config TRACE
  depends on !ICARUS
  bool "Enable tracer"
  default y

config TRACE_START
  depends on TRACE
  int "When tracing is enabled (unit: number of instructions)"
  default 0 

config TRACE_END
  depends on TRACE
  int "When tracing is disabled (unit: number of instructions)"
  default 10000

config ITRACE
  depends on TRACE 
  bool "Enable instruction tracer"
  default y

config LOOP_DETECT
  depends on ITRACE
  bool "Enable detect die loop"
  default n
  
config WATCHPOINT
  depends on ITRACE
  bool "Enable watchpoint"
  default y

config MTRACE
  depends on TRACE
  bool "Enable memory trace"
  default n

config MTRACE_BASE
  depends on MTRACE
  hex "memory tracer base address"
  default 0x80000000 

config MTRACE_SIZE
  depends on MTRACE
  hex "memory tracer size"
  default 0x1000

config FTRACE
  depends on TRACE
  bool "Enable function trace"
  default n 

config DTRACE
  depends on TRAC
  bool "Enable device trace"
  default n 

config PERF_CAL
  depends on !ICARUS
  bool "Enable performance calculation"
  default y

config DIFFTEST
  depends on !ICARUS
  bool "Enable differential testing"
  default n
  help
    Enable differential testing with a reference design.
    Note that this will significantly reduce the performance of CPU.

choice
  prompt "Reference design"
  # default DIFFTEST_REF_SPIKE 
  # default DIFFTEST_REF_QEMU
  default DIFFTEST_REF_NEMU 
  depends on DIFFTEST
config DIFFTEST_REF_QEMU
  bool "QEMU, communicate with socket"
config DIFFTEST_REF_SPIKE
  bool "Spike"
config DIFFTEST_REF_NEMU
  bool "NEMU"
endchoice

# config DIFFTEST_REF_PATH
#   string
#   default "tools/qemu-diff" if DIFFTEST_REF_QEMU
#   default "tools/spike-diff" if DIFFTEST_REF_SPIKE
#   default "none"

config DIFFTEST_REF_NAME
  string
  default "qemu" if DIFFTEST_REF_QEMU
  default "spike" if DIFFTEST_REF_SPIKE
  default "nemu" if DIFFTEST_REF_NEMU
  default "none"

config ENGINE
  string
  default "interpreter"

endmenu


if MODE_SYSTEM
source "csrc/memory/Kconfig"
# source "csrc/device/Kconfig"
endif

menu "Miscellaneous"
choice
  prompt "Host timer"
  default TIMER_GETTIMEOFDAY
config TIMER_GETTIMEOFDAY
  bool "gettimeofday"
config TIMER_CLOCK_GETTIME
  bool "clock_gettime"
endchoice

endmenu
